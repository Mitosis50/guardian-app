{
  "name": "agent-guardian-tray",
  "version": "0.1.1",
  "description": "Agent Guardian menubar/system tray app for encrypted IPFS backups.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "./node_modules/electron/dist/Electron.app/Contents/MacOS/Electron .",
    "build:mac": "electron-builder --mac dmg --arm64 --x64",
    "build:win": "electron-builder --win nsis --x64",
    "test": "node --test tests/**/*.test.js",
    "test:arweave": "node tests/arweave-integration.test.js",
    "build:mac:ci": "electron-builder --mac dmg --arm64",
    "scan:secrets": "node scripts/secret-scan.js",
    "prepare:githooks": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@pinata/sdk": "^2.1.0",
    "arweave": "^1.15.7",
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.agentguardian.tray",
    "productName": "Agent Guardian",
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "renderer/**/*",
      "assets/**/*",
      "AI_AGENT_INSTALL_GUIDE.md",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/AppIcon.icns",
      "darkModeSupport": true,
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false,
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "copyright": "Copyright © 2026 Dr. Elbert Basa",
    "afterSign": "scripts/notarize.js"
  },
  "author": {
    "name": "Dr. Elbert Basa",
    "email": "support@agentbotguardian.com",
    "url": "https://agentbotguardian.com"
  },
  "homepage": "https://agentbotguardian.com",
  "license": "SEE LICENSE IN LICENSE"
}
